{
  "version": 2,
  "headers": [
    {
      "source": "/__/auth/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ],
  "rewrites": [
    { 
      "source": "/__/auth/:path*", 
      "destination": "https://sportsbox-1.firebaseapp.com/__/auth/:path*" 
    },
    { "source": "/api", "destination": "/api/index.ts" },
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/((?!api|__/auth|sitemap|robots|logo|.*\\.).*)", "destination": "/index.html" }
  ]
}