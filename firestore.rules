rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helpers
    function isSignedIn() { return request.auth != null; }
    
    function isAdmin() { 
      return isSignedIn() && 
             request.auth.token != null &&
             'email' in request.auth.token &&
             (request.auth.token.email == 'sohailgaji9097@gmail.com' ||
              request.auth.token.email == 'tavish@dreamcatchers.tv' ||
              request.auth.token.email == 'Sohailgaji9097@gmail.com' ||
              request.auth.token.email == 'Tavish@dreamcatchers.tv');
    }
    
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    // Users: owners/admins can read/write their own info
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    // Blogs: everyone can read, only admin can write
    match /blogs/{blogId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // Settings: site configurations (videoPromo, siteConfig, playerConfig) - read for all, write for admin
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // Subscription Plans: read for all, write for admin
    match /subscription_plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // Slider: read for all, write for admin
    match /slider/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // Sections: read for all, write for admin
    match /sections/{sectionId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // Subscriptions: read for all, write for admin
    match /subscriptions/{subId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // Library and Library Folders: read/write for Admin only
    match /library/{libId} {
      allow read, write: if isAdmin();
    }
    match /library_folders/{folderId} {
      allow read, write: if isAdmin();
    }
    // Olympic Medalists: everyone can read, only admin can write
    match /olympic_medalists/{medalistId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // Content/Videos/Streams: everyone can read, only admin can write (except dynamic increments of viewCount, likes, or liveViewerCount on update)
    match /content/{contentId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        // Allow anyone to update viewCount, uniqueViewsCount, likes, or liveViewerCount (real-time live spectator presence)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'likes', 'uniqueViewsCount', 'liveViewerCount'])
      );
      
      // Unique views subcollection: guest/anonymous read/write
      match /unique_views/{viewId} {
        allow read, write: if true;
      }
      
      // Comments subcollection: signed-in users can read/write
      match /comments/{commentId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
      // Spectators subcollection: guest/anonymous read/write for real-time presence
      match /spectators/{spectatorId} {
        allow read, write: if true;
      }
      // Likes subcollection: anyone can verify/write their own likes under their uid
      match /likes/{userId} {
        allow read: if true;
        allow write: if isOwner(userId) || isAdmin();
      }
    }
  }
}
