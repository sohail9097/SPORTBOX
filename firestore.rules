rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && 
             (request.auth.token.email.lower() == 'sohailgaji9097@gmail.com' ||
              request.auth.token.email.lower() == 'tavish@dreamcatchers.tv');
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // Broad permissive rules for everything during migration/debug
    match /{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Specific user protection
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
  }
}
