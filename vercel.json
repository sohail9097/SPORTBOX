{
  "version": 2,
  "rewrites": [
    { "source": "/api", "destination": "/api/index.ts" },
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/__/auth/:path*", "destination": "https://sportsbox-1.firebaseapp.com/__/auth/:path*" },
    { "source": "/((?!api|sitemap|robots|logo|.*\\.).*)", "destination": "/index.html" }
  ]
}
